(* Sum (enum) *)
type e = [ Alpha | Beta ]

(* Sum *)
type sample_sum = [
  | Simple_tag
  | Bool of bool
  | Int of int
  | Float of float
  | String <java name="S"> of string
  | Simple_record of simple_record
  | Complex_record of complex_record
  | Record_with_defaults of record_with_defaults
]

(* Record *)
type complex_record = {
  b <doc text="foo bar baz"> : bool;
  i : int;
  s : string;
  l : bool list;
  sample_sum : sample_sum;

  (* Java keywords used as field names *)
  ?class : int option;
  ?final <java name="is_final"> : int option;

  (* List of records *)
  l2 : record_with_defaults list;
}

<doc text="wibble">

(* Record with default fields *)
type record_with_defaults = {
  ~b : bool;
  ~i : int;
  ~s : string;
  ~o : bool option;
  ~l : bool list;
  ~e : e;
}

(* Record with optional field *)
type simple_record = { ?o : bool option }

(* https://github.com/esperco/atdj/issues/2 *)
type a = [ A of b list ]
type b = [ B ]

(* Type alias for a list - Java doesn't support type aliases, so we generate
   a wrapper class with the same JSON interface as record classes. *)
type items = simple_record list

(*
  Sum type using the object encoding: {"Constructor": payload}
  instead of the default array encoding: ["Constructor", payload].

  This matches the Rust/Serde default (externally-tagged) and also
  looks natural in YAML:

    # array encoding (default):
    - - Circle
      - 3.14
    # object encoding (<json repr="object">):
    - Circle: 3.14
*)
type shape = [
  | Circle of float
  | Square of float
  | Point              (* unit variant -- always encoded as a plain string *)
] <json repr="object">
