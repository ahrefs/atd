(** A binary tree. *)
and tree =
  | Leaf
  | Node of node

let make_node ~value ~left ~right () : node =
  { value; left; right }

let rec node_of_yojson (x : Yojson.Safe.t) : node =
  match x with
  | `Assoc fields ->
    let value =
      match List.assoc_opt "value" fields with
      | Some v -> Atdml_runtime.int_of_yojson v
      | None -> Atdml_runtime.missing_field "node" "value"
    in
