      match List.assoc_opt "left" fields with
      | Some v -> tree_of_yojson v
      | None -> Atdml_runtime.missing_field "node" "left"
    in
    let right =
      match List.assoc_opt "right" fields with
      | Some v -> tree_of_yojson v
      | None -> Atdml_runtime.missing_field "node" "right"
    in
    { value; left; right }
  | _ -> Atdml_runtime.bad_type "node" x

and tree_of_yojson (x : Yojson.Safe.t) : tree =
  match x with
  | `String "Leaf" -> Leaf
  | `List [`String "Node"; v] -> Node (node_of_yojson v)
  | _ -> Atdml_runtime.bad_sum "tree" x

let rec yojson_of_node (x : node) : Yojson.Safe.t =
  `Assoc (List.concat [
    [("value", Atdml_runtime.yojson_of_int x.value)];
    [("left", yojson_of_tree x.left)];
    [("right", yojson_of_tree x.right)];
  ])

and yojson_of_tree (x : tree) : Yojson.Safe.t =
  match x with
  | Leaf -> `String "Leaf"
  | Node v -> `List [`String "Node"; yojson_of_node v]

